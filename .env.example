# Development-only sample values. Copy this file to .env before starting Compose.
CAMERA_ID=camera-dev-1
CAMERA_DEVICE=0
CAMERA_API_TOKEN=change-me-development-token
MODEL_PATH=yolo26n-pose.pt
PROCESS_FPS=10
SERVER_BASE_URL=http://server:8000
DATABASE_PATH=/data/fall_detection.sqlite3
VIDEO_DIR=/data/videos
SESSION_SECRET=change-me-development-session-secret
AUTH_DISABLED=true
SIMULATE_FALL=true
# Set to `id -u` / `id -g` when the host account differs from 1000.
HOST_UID=1000
HOST_GID=1000
