# Development-only sample values. Copy this file to .env before starting Compose.
CAMERA_ID=camera-dev-1
HOST_CAMERA_DEVICE=/dev/video0
CAMERA_DEVICE=/dev/video0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_API_TOKEN=change-me-development-token
MODEL_PATH=yolo26n-pose.pt
PROCESS_FPS=10
POSE_DEVICE=0
POSE_CONFIDENCE=0.5
POSE_IMAGE_SIZE=640
SHOW_WINDOW=true
MAX_CAMERA_READ_FAILURES=10
FALL_CANDIDATE_SECONDS=1.0
FALL_BBOX_ASPECT_THRESHOLD=1.15
FALL_TORSO_ANGLE_THRESHOLD=60.0
SERVER_BASE_URL=http://server:8000
DATABASE_PATH=/data/fall_detection.sqlite3
VIDEO_DIR=/data/videos
MAX_VIDEO_UPLOAD_BYTES=52428800
SESSION_SECRET=development-session-secret-please-change-32
SESSION_TTL_SECONDS=28800
SESSION_COOKIE_SECURE=false
MONITOR_USERNAME=admin
MONITOR_PASSWORD_HASH=pbkdf2_sha256:260000:ZmFsbC1kZW1vLWFkbWlu:tcQHQcZZ13ziZCIsA1snbLFBRRkpIogw7nRWAep8jP0
AUTH_DISABLED=false
# Set to `id -u` / `id -g` when the host account differs from 1000.
HOST_UID=1000
HOST_GID=1000
# Set to `getent group video | cut -d: -f3` when the host video group differs.
VIDEO_GID=44
